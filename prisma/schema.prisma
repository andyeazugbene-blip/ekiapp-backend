generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  BUYER
  VENDOR
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  CONFIRMED
  PROCESSING
  DISPATCHED
  IN_TRANSIT
  DELIVERED
  COMPLETED
  CANCELLED
  REFUNDED
  FAILED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
}

enum WalletTransactionType {
  PENDING_TO_AVAILABLE
  PAYMENT_PENDING_CREDIT
  PAYOUT_DEBIT
  ADJUSTMENT_CREDIT
  ADJUSTMENT_DEBIT
}

enum WebhookEventStatus {
  PROCESSING
  PROCESSED
  IGNORED
}

enum PayoutRequestStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum VendorVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum PayoutMethodType {
  BANK_TRANSFER
  MOBILE_MONEY
  WISE
  PAYONEER
  OTHER
}

enum NotificationType {
  ORDER_PAID
  BALANCE_CREDITED
  PAYOUT_REQUESTED
  PAYOUT_APPROVED
  PAYOUT_REJECTED
  PAYOUT_PAID
}

enum ReviewStatus {
  PENDING
  APPROVED
  HIDDEN
  REJECTED
}

model User {
  id            String         @id @default(cuid())
  email               String         @unique
  name                String
  password            String
  phone               String?
  avatar              String?
  country             String?
  referralCode        String?        @unique
  referredBy          String?
  tokenVersion        Int            @default(0)
  failedLoginAttempts Int            @default(0)
  lockedUntil         DateTime?
  emailVerifiedAt     DateTime?
  role                UserRole       @default(BUYER)
  vendor              Vendor?
  orders              Order[]        @relation("BuyerOrders")
  cart                Cart?
  notifications       Notification[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([role, createdAt])
  @@index([createdAt])
}

model Vendor {
  id                    String                   @id @default(cuid())
  userId                String                   @unique
  storeName             String
  storeSlug             String                   @unique
  description           String?
  contactEmail          String?
  contactPhone          String?
  country               String?
  city                  String?
  avatar                String?
  coverImage            String?
  isSuspended           Boolean                  @default(false)
  suspendedReason       String?
  stripeAccountId       String?                  @unique
  stripeAccountStatus   String?
  stripePayoutsEnabled  Boolean                  @default(false)
  stripeChargesEnabled  Boolean                  @default(false)
  stripeOnboardedAt     DateTime?
  verificationStatus    VendorVerificationStatus @default(PENDING)
  user                  User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet                Wallet?
  products              Product[]
  orderItems            OrderItem[]
  walletTransactions    WalletTransaction[]
  payoutMethods         PayoutMethod[]
  payoutRequests        PayoutRequest[]
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([verificationStatus, createdAt])
  @@index([createdAt])
  @@index([isSuspended])
}

model PayoutMethod {
  id             String           @id @default(cuid())
  vendorId       String
  type           PayoutMethodType
  label          String?
  details        Json
  isDefault      Boolean          @default(false)
  vendor         Vendor           @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  payoutRequests PayoutRequest[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([vendorId])
}

model PayoutRequest {
  id                 String              @id @default(cuid())
  vendorId           String
  payoutMethodId     String
  amount             Int
  currency           String              @default("eur")
  status             PayoutRequestStatus @default(PENDING)
  notes              String?
  rejectionReason    String?
  approvedById       String?
  approvedAt         DateTime?
  paidById           String?
  paidAt             DateTime?
  vendor             Vendor              @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  payoutMethod       PayoutMethod        @relation(fields: [payoutMethodId], references: [id], onDelete: Restrict)
  walletTransactions WalletTransaction[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([vendorId, status])
  @@index([status, createdAt])
}

model Product {
  id           String      @id @default(cuid())
  vendorId     String
  title        String
  description  String?
  priceInCents Int
  currency     String      @default("eur")
  images       String[]    @default([])
  category     String?
  stock        Int         @default(0)
  weightGrams  Int?
  isActive     Boolean     @default(true)
  vendor       Vendor      @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  orderItems   OrderItem[]
  cartItems    CartItem[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([vendorId, title])
  @@index([vendorId, isActive])
  @@index([isActive, category])
  @@index([createdAt])
}

model Cart {
  id        String     @id @default(cuid())
  buyerId   String     @unique
  buyer     User       @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  quantity  Int
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
  @@index([cartId])
}

model Order {
  id                 String              @id @default(cuid())
  orderNumber        String              @unique @default(cuid())
  checkoutId         String?
  buyerId            String
  vendorId           String?
  status             OrderStatus         @default(PENDING)
  subtotalAmount     Int                 @default(0)
  deliveryFeeAmount  Int                 @default(0)
  platformFeeAmount  Int                 @default(0)
  vendorEarnings     Int                 @default(0)
  totalAmount        Int
  currency           String              @default("eur")
  deliveryZoneId     String?
  notes              String?
  deliveredAt        DateTime?
  checkout           Checkout?           @relation(fields: [checkoutId], references: [id], onDelete: SetNull)
  buyer              User                @relation("BuyerOrders", fields: [buyerId], references: [id], onDelete: Restrict)
  deliveryZone       DeliveryZone?       @relation(fields: [deliveryZoneId], references: [id], onDelete: SetNull)
  items              OrderItem[]
  payment            Payment?
  walletTransactions WalletTransaction[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([checkoutId])
  @@index([buyerId, status])
  @@index([vendorId, status])
  @@index([status, createdAt])
  @@index([createdAt])
}

model Checkout {
  id                    String        @id @default(cuid())
  buyerId               String
  stripePaymentIntentId String?       @unique
  totalAmount           Int
  currency              String        @default("eur")
  status                PaymentStatus @default(PENDING)
  metadata              Json?
  processedAt           DateTime?
  orders                Order[]
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([buyerId])
  @@index([status])
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  productId    String
  vendorId     String
  quantity     Int
  unitAmount   Int
  totalAmount  Int
  currency     String   @default("eur")
  productTitle String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  vendor       Vendor   @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([orderId])
  @@index([vendorId])
}

model Payment {
  id                    String              @id @default(cuid())
  orderId               String              @unique
  stripePaymentIntentId String?             @unique
  amount                Int
  platformFeeAmount     Int
  vendorEarningsAmount  Int
  currency              String              @default("eur")
  status                PaymentStatus       @default(PENDING)
  provider              String              @default("stripe")
  metadata              Json?
  processedAt           DateTime?
  order                 Order               @relation(fields: [orderId], references: [id], onDelete: Restrict)
  walletTransactions    WalletTransaction[]
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([status])
  @@index([status, createdAt])
  @@index([createdAt])
}

model Wallet {
  id               String              @id @default(cuid())
  vendorId         String              @unique
  pendingBalance   Int                 @default(0)
  availableBalance Int                 @default(0)
  currency         String              @default("eur")
  vendor           Vendor              @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  transactions     WalletTransaction[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

model WalletTransaction {
  id              String                @id @default(cuid())
  walletId        String
  vendorId        String
  orderId         String?
  paymentId       String?
  payoutRequestId String?
  type            WalletTransactionType
  amount          Int
  currency        String                @default("eur")
  description     String?
  wallet          Wallet                @relation(fields: [walletId], references: [id], onDelete: Restrict)
  vendor          Vendor                @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  order           Order?                @relation(fields: [orderId], references: [id], onDelete: Restrict)
  payment         Payment?              @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  payoutRequest   PayoutRequest?        @relation(fields: [payoutRequestId], references: [id], onDelete: Restrict)
  createdAt       DateTime              @default(now())

  @@unique([vendorId, orderId, paymentId, type])
  @@unique([payoutRequestId, type])
  @@index([walletId, createdAt])
  @@index([vendorId, createdAt])
  @@index([orderId])
  @@index([paymentId])
  @@index([payoutRequestId])
}

// ─── Reviews ────────────────────────────────────────────────────────────────

model Review {
  id         String       @id @default(cuid())
  buyerId    String
  vendorId   String
  productId  String?
  orderId    String
  rating     Int          // 1-5
  comment    String?
  status     ReviewStatus @default(PENDING)
  moderatedBy String?
  moderatedAt DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@unique([buyerId, orderId, productId])
  @@index([vendorId, status])
  @@index([productId, status])
  @@index([buyerId])
  @@index([status, createdAt])
}

model DeliveryZone {
  id              String           @id @default(cuid())
  name            String
  country         String
  flag            String?
  baseFeeAmount   Int
  feePerKgAmount  Int
  currency        String           @default("eur")
  isActive        Boolean          @default(true)
  vendorId        String?
  orders          Order[]
  deliveryMethods DeliveryMethod[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([country, isActive])
  @@index([vendorId, isActive])
}

model DeliveryMethod {
  id             String       @id @default(cuid())
  deliveryZoneId String
  label          String
  priceAmount    Int
  minDays        Int
  maxDays        Int
  isActive       Boolean      @default(true)
  deliveryZone   DeliveryZone @relation(fields: [deliveryZoneId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([deliveryZoneId, isActive])
}

// ─── Phase 3: Shipment Tracking ─────────────────────────────────────────────

enum ShipmentStatus {
  PROCESSING
  IN_TRANSIT
  DELIVERED
  DELAYED
}

model Shipment {
  id                   String         @id @default(cuid())
  orderId              String         @unique
  vendorId             String
  trackingNumber       String?
  carrier              String?
  status               ShipmentStatus @default(PROCESSING)
  estimatedDeliveryAt  DateTime?
  dispatchedAt         DateTime?
  deliveredAt          DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@index([vendorId, status])
  @@index([status])
  @@index([orderId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  data      Json?
  readAt    DateTime?
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@index([type])
}

model WebhookEvent {
  id            String             @id @default(cuid())
  stripeEventId String             @unique
  eventType     String
  provider      String             @default("stripe")
  status        WebhookEventStatus @default(PROCESSING)
  paymentId     String?
  orderId       String?
  createdAt     DateTime           @default(now())
  processedAt   DateTime?

  @@index([status, createdAt])
  @@index([eventType])
  @@index([paymentId])
  @@index([orderId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ─── Email OTP Verification ─────────────────────────────────────────────────

model EmailOtp {
  id         String    @id @default(cuid())
  email      String
  codeHash   String
  purpose    String    @default("vendor_onboarding_email")
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())

  @@index([email, purpose, createdAt])
  @@index([expiresAt])
}

// ─── Phase 2: Messaging ──────────────────────────────────────────────────────

enum ConversationType {
  BUYER_VENDOR
  ADMIN_VENDOR
  DISPUTE
}

model Conversation {
  id            String           @id @default(cuid())
  type          ConversationType @default(BUYER_VENDOR)
  participantA  String
  participantB  String
  orderId       String?
  lastMessageAt DateTime?
  messages      Message[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@unique([participantA, participantB, orderId])
  @@index([participantA, lastMessageAt])
  @@index([participantB, lastMessageAt])
  @@index([orderId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  text           String
  attachments    String[]     @default([])
  readAt         DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
  @@index([senderId])
}

// ─── Phase 2: Verification Documents ────────────────────────────────────────

enum VerificationDocType {
  GOVERNMENT_ID
  BUSINESS_REGISTRATION
}

enum VerificationDocStatus {
  PENDING
  APPROVED
  REJECTED
}

model VerificationDocument {
  id              String                @id @default(cuid())
  vendorId        String
  type            VerificationDocType
  idType          String?
  frontUrl        String
  backUrl         String?
  status          VerificationDocStatus @default(PENDING)
  reviewedById    String?
  reviewedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([vendorId, type])
  @@index([status])
}

// ─── Phase 2: Buyer Addresses ───────────────────────────────────────────────

model BuyerAddress {
  id            String   @id @default(cuid())
  buyerId       String
  recipientName String
  line1         String
  line2         String?
  city          String
  postalCode    String
  country       String
  phone         String?
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([buyerId])
}

// ─── Phase 4: Audit Log ─────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([entityType, entityId])
  @@index([action, createdAt])
  @@index([createdAt])
}

// ─── Phase 5: Buyer Wallet ──────────────────────────────────────────────────

enum BuyerWalletTxType {
  TOP_UP
  REFERRAL_BONUS
  ORDER_DEBIT
  REFUND_CREDIT
  WITHDRAWAL
}

model BuyerWallet {
  id           String                 @id @default(cuid())
  buyerId      String                 @unique
  balance      Int                    @default(0)
  currency     String                 @default("eur")
  transactions BuyerWalletTransaction[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
}

model BuyerWalletTransaction {
  id               String           @id @default(cuid())
  walletId         String
  buyerId          String
  type             BuyerWalletTxType
  amount           Int
  currency         String           @default("eur")
  description      String?
  orderId          String?
  paymentIntentId  String?
  wallet           BuyerWallet      @relation(fields: [walletId], references: [id], onDelete: Restrict)
  createdAt        DateTime         @default(now())

  @@unique([paymentIntentId, type])
  @@index([walletId, createdAt])
  @@index([buyerId, createdAt])
}

// ─── Phase 5: Promo Codes ───────────────────────────────────────────────────

enum PromoType {
  PERCENTAGE
  FIXED_AMOUNT
}

model PromoCode {
  id             String           @id @default(cuid())
  code           String           @unique
  type           PromoType
  value          Int
  minOrderAmount Int?
  maxUses        Int?
  usedCount      Int              @default(0)
  validFrom      DateTime         @default(now())
  validUntil     DateTime?
  isActive       Boolean          @default(true)
  redemptions    PromoRedemption[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([code, isActive])
  @@index([isActive, validFrom, validUntil])
}

model PromoRedemption {
  id             String    @id @default(cuid())
  promoCodeId    String
  buyerId        String
  orderId        String?
  discountAmount Int
  promoCode      PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Restrict)
  createdAt      DateTime  @default(now())

  @@unique([promoCodeId, buyerId])
  @@index([buyerId])
}

// ─── Phase 5: Referrals ─────────────────────────────────────────────────────

model Referral {
  id           String   @id @default(cuid())
  referrerId   String
  referredId   String   @unique
  bonusAmount  Int
  currency     String   @default("eur")
  creditedAt   DateTime?
  createdAt    DateTime @default(now())

  @@index([referrerId])
}

// ─── Phase 8: Subscriptions ─────────────────────────────────────────────────

enum SubscriptionPlan {
  FREE
  BASIC
  GROWTH
  PREMIUM
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PAST_DUE
}

model VendorSubscription {
  id                   String             @id @default(cuid())
  vendorId             String             @unique
  plan                 SubscriptionPlan   @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  stripeSubscriptionId String?            @unique
  stripeCustomerId     String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelledAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([status])
  @@index([plan])
}

// ─── Push Notifications (Expo) ──────────────────────────────────────────────

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String
  platform  String?
  createdAt DateTime @default(now())

  @@unique([userId, token])
  @@index([userId])
}
