NODE_ENV=development
PORT=4000
# Comma-separated allowed origins for CORS. Leave empty to allow all (dev mode).
# Example: https://yourapp.com,https://admin.yourapp.com
CORS_ORIGINS=
# Local development: any standard Postgres URL works.
# Production on Vercel (serverless): use a Neon POOLED connection string
# (host contains `-pooler`, e.g.
#   postgresql://USER:PASS@ep-xxx-pooler.region.aws.neon.tech/db?sslmode=require&pgbouncer=true&connection_limit=1
# ). Pooled URLs are required because each warm Lambda holds its own
# Prisma client; the connection pool prevents exhausting Postgres.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/marketplace_payments?schema=public"
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here 
DEFAULT_CURRENCY=usd
PLATFORM_FEE_BPS=1000
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d
# Optional: enable Sentry error monitoring by setting your project DSN.
# Leave empty in local dev to disable.
SENTRY_DSN=
# Optional: enable BullMQ queues (notifications, emails, payouts) by
# pointing at a Redis instance. Leave empty in local dev to disable
# queueing; the app still runs without Redis.
REDIS_URL=
# Resend API key for transactional emails. Leave empty in local dev
# to log emails instead of sending them.
RESEND_API_KEY=
# From address for outgoing emails.
EMAIL_FROM=Eki Marketplace <noreply@ekiapp.com>
# Frontend URL for links in emails (password reset, etc.)
FRONTEND_URL=http://localhost:3000
# Public base URL for vendor storefront share links (no trailing slash).
# Vendor share URLs are formatted: {PUBLIC_STORE_BASE_URL}/store/{slug}
PUBLIC_STORE_BASE_URL=https://neon.online
# Base URL for uploaded files (S3/R2 bucket public URL).
UPLOAD_BASE_URL=/uploads

# ─── S3/Cloudflare R2 Storage ────────────────────────────────────────────────
# Required for production file uploads. Leave empty for dev (mock URLs).
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=https://your-cdn.example.com

# ─── Admin Bootstrap ─────────────────────────────────────────────────────────
# Set these to auto-create the first admin on startup. Remove after first boot.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Admin
