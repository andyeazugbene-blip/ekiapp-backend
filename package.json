{
  "name": "marketplace-payments-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Backend payment foundation for a multi-vendor marketplace",
  "main": "dist/src/server.js",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "tsx src/server.ts",
    "dev:watch": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/src/server.js",
    "vercel-build": "prisma generate && prisma migrate deploy",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "prisma db seed",
    "db:bootstrap": "prisma migrate deploy && prisma db seed",
    "launch:health": "tsx scripts/launch-health-check.ts",
    "launch:load-smoke": "tsx scripts/load-smoke-test.ts",
    "check:scaffolding": "tsx scripts/check-ai-scaffolding.ts",
    "test:coverage-map": "tsx scripts/module-test-coverage.ts",
    "verify:sustainability": "tsx scripts/check-ai-scaffolding.ts && tsx scripts/module-test-coverage.ts && npx tsc --noEmit && npx vitest run",
    "test:scenario": "tsx scripts/scenario-marketplace-test.ts",
    "test:scenario:low": "tsx scripts/scenario-marketplace-test.ts",
    "test:security:ratelimit": "tsx scripts/security-ratelimit-test.ts",
    "audit:security": "tsx scripts/security-audit.ts",
    "cleanup:scenario": "tsx scripts/cleanup-scenario-products.ts",
    "seed:qa": "tsx scripts/seed-qa-data.ts",
    "cleanup:qa": "tsx scripts/cleanup-qa-data.ts",
    "seed:escrow": "tsx scripts/seed-escrow-scenarios.ts",
    "seed:otp": "tsx scripts/seed-otp-scenarios.ts",
    "validate:qa": "tsx scripts/validate-qa-seed.ts",
    "repair:qa-ledger": "tsx scripts/repair-qa-ledger.ts",
    "reconcile:stripe": "tsx scripts/reconcile-stripe.ts",
    "reconcile:paystack": "tsx scripts/reconcile-paystack.ts",
    "reconcile:wallets": "tsx scripts/reconcile-wallets.ts",
    "r2:round-trip": "tsx scripts/r2-round-trip.ts",
    "register:smoke": "tsx scripts/register-smoke.ts",
    "check:domains": "tsx scripts/check-domain-links.ts",
    "check:no-old-domain": "tsx scripts/check-no-old-domain.ts",
    "test:payout-flow": "tsx scripts/test-payout-flow.ts",
    "prepare": "husky"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "overrides": {
    "lodash": "^4.18.1",
    "axios": "^1.16.0",
    "qs": "^6.15.2"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@prisma/client": "^6.0.0",
    "@sentry/node": "^10.52.0",
    "africastalking": "^0.7.4",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.76.6",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "otplib": "^12.0.1",
    "resend": "^6.12.3",
    "stripe": "^18.5.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.1",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@vercel/node": "^5.8.1",
    "husky": "^9.1.7",
    "prisma": "^6.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  }
}
