{
    "version": 2,
    "buildCommand": "npm run vercel-build",
    "installCommand": "npm install",
    "functions": {
        "api/index.ts": {
            "maxDuration": 30,
            "includeFiles": "src/**,prisma/**"
        }
    },
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/api"
        }
    ]
}
